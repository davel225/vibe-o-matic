# vibe-o-matic — environment variables
#
# Copy to .env.local (which is gitignored) and fill in real values.
# In Vercel: add the same vars under Settings → Environment Variables.

# ── Required for image generation ─────────────────────────────────
# gpt-4o-mini vision describer + x402 agent picker
OPENAI_API_KEY=sk-...

# Black Forest Labs FLUX.2 [pro] — image renderer
BFL_API_KEY=...

# ── Required for the x402 USDC rail on Base mainnet ────────────────
# Sign up at https://portal.cdp.coinbase.com/ → Create API Key.
# These authenticate our server to Coinbase's hosted x402 facilitator,
# which is the only public facilitator that supports Base mainnet
# settlement (x402.org's free facilitator is testnet-only).
CDP_API_KEY_ID=...
CDP_API_KEY_SECRET=...

# ── Optional ───────────────────────────────────────────────────────
# Set to "1" to enable the in-UI test-mode toggle that renders without
# payment. MUST be unset in production (gate is server-side, so leaving
# it on would let anyone render for free).
# VIBEIFY_ALLOW_BYPASS=1
